{
  "version": 2,
  "builds": [
    { "src": "api/audit.py", "use": "@vercel/python" },
    { "src": "frontend/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/audit", "dest": "/api/audit.py" },
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
